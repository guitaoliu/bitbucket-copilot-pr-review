pipeline {
  agent { label "DK_UBCOMMON2404" }

  environment {
    BITBUCKET_BASE_URL = "https://bitbucket.example.com"
    BITBUCKET_PROJECT_KEY = "PROJ"
    BITBUCKET_REPO_SLUG = "my-service"
    REPO_ROOT = "${WORKSPACE}"
    REPORT_LINK = "${BUILD_URL}"
  }

  options {
    timestamps()
    disableConcurrentBuilds(abortPrevious: true)
  }

  stages {
    stage("Tooling") {
      steps {
        sh "n lts && hash -r && npm install -g pnpm@10 && node -v && pnpm -v"
      }
    }

    stage("Install") {
      steps {
        sh "pnpm install --frozen-lockfile"
      }
    }

    stage("Typecheck") {
      steps {
        sh "pnpm typecheck"
      }
    }

    stage("AI Review") {
      steps {
        withCredentials([
          string(credentialsId: "github-copilot-token", variable: "COPILOT_GITHUB_TOKEN"),
          string(credentialsId: "bitbucket-review-token", variable: "BITBUCKET_TOKEN")
        ]) {
          sh '''
            PR_URL="${BITBUCKET_BASE_URL}/projects/${BITBUCKET_PROJECT_KEY}/repos/${BITBUCKET_REPO_SLUG}/pull-requests/${CHANGE_ID}"
            pnpm review -- "$PR_URL"
          '''
        }
      }
    }
  }
}
