{
	"$schema": "./schemas/copilot-code-review.schema.json",
	"review": {
		"maxFiles": 300,
		"maxFindings": 25,
		"minConfidence": "medium",
		"maxPatchChars": 12000,
		"defaultFileSliceLines": 250,
		"maxFileSliceLines": 400,
		"skipBranchPrefixes": ["renovate/"]
	},
	"report": {
		"commentStrategy": "recreate"
	}
}
